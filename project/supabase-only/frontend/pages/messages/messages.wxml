<view class="container">
  <view class="card">
    <view class="title">留言板</view>
    <input class="input" placeholder="写点想说的话..." bindinput="onInput" value="{{content}}" />
    <button class="btn-primary" bindtap="send">发送留言</button>
  </view>

  <block wx:for="{{list}}" wx:key="id">
    <view class="card">
      <view style="font-weight:600">{{item.sender}}</view>
      <view style="margin:8rpx 0">{{item.content}}</view>
      <view style="font-size:24rpx;color:#999">{{item.created_at}}</view>
    </view>
  </block>
</view>
