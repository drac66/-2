<view class="container">
  <view class="card">
    <view class="title">日记</view>
    <input class="input" placeholder="标题（可选）" bindinput="onTitle" value="{{title}}" />
    <textarea class="input" style="height:180rpx" placeholder="写下今天的心情..." bindinput="onContent" value="{{content}}" />
    <picker mode="selector" range="{{['仅自己可见','双方可见']}}" bindchange="onVisibility" value="{{visibility==='self'?0:1}}">
      <view class="input">可见性：{{visibility==='self'?'仅自己可见':'双方可见'}}</view>
    </picker>
    <button class="btn-primary" bindtap="save">保存日记</button>
  </view>

  <block wx:for="{{list}}" wx:key="id">
    <view class="card list-gap">
      <view class="section-title">{{item.author}}</view>
      <view class="meta">{{item.visibility==='self'?'仅自己可见':'双方可见'}}</view>
      <view wx:if="{{item.title}}" class="mt-8">{{item.title}}</view>
      <view class="mt-8" style="white-space:pre-wrap">{{item.content}}</view>
      <view class="meta mt-8">{{item.created_at}}</view>
    </view>
  </block>
</view>
