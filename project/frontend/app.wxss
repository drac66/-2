page { background: #fff6fa; color: #333; font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', sans-serif; }
.container { padding: 24rpx; }
.card { background: #fff; border-radius: 20rpx; padding: 24rpx; margin-bottom: 20rpx; box-shadow: 0 8rpx 20rpx rgba(255, 122, 162, 0.12); }
.title { font-size: 34rpx; font-weight: 700; margin-bottom: 20rpx; color: #ff5c8d; }
.btn-primary { background: linear-gradient(135deg, #ff7aa2, #ff5c8d); color: #fff; border: none; border-radius: 999rpx; }
.input { background: #fff; border-radius: 12rpx; border: 1rpx solid #ffd2df; padding: 16rpx; margin-bottom: 16rpx; }
