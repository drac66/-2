page {
  background-color: #eaf8ff;
  background-image:
    linear-gradient(rgba(255, 255, 255, 0.14), rgba(255, 255, 255, 0.14)),
    url('/assets/wallpaper.jpg');
  background-size: cover;
  background-position: center;
  background-repeat: no-repeat;
  color: #1f2d3d;
  font-family: 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
}

.container { padding: 24rpx; }

.card {
  background: rgba(255, 255, 255, 0.22);
  border: 1rpx solid rgba(255, 255, 255, 0.44);
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 10rpx 28rpx rgba(33, 102, 66, 0.15);
  backdrop-filter: blur(14rpx);
}

.surface {
  position: relative;
  overflow: hidden;
  border-radius: 32rpx;
  padding: 28rpx 26rpx;
  margin-bottom: 22rpx;
  background: linear-gradient(180deg, rgba(70, 183, 255, 0.88), rgba(140, 225, 255, 0.74));
  border: 1rpx solid rgba(255, 255, 255, 0.45);
  box-shadow: 0 18rpx 36rpx rgba(46, 142, 219, 0.25);
}

.cloud {
  position: absolute;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 999rpx;
  box-shadow: 0 4rpx 12rpx rgba(255, 255, 255, 0.4);
}

.cloud::before,
.cloud::after {
  content: '';
  position: absolute;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 999rpx;
}

.cloud-a {
  width: 138rpx;
  height: 54rpx;
  top: 22rpx;
  right: 24rpx;
}
.cloud-a::before { width: 56rpx; height: 56rpx; left: 16rpx; top: -24rpx; }
.cloud-a::after { width: 50rpx; height: 50rpx; right: 18rpx; top: -20rpx; }

.cloud-b {
  width: 108rpx;
  height: 42rpx;
  top: 82rpx;
  right: 132rpx;
  opacity: 0.78;
}
.cloud-b::before { width: 42rpx; height: 42rpx; left: 12rpx; top: -16rpx; }
.cloud-b::after { width: 36rpx; height: 36rpx; right: 12rpx; top: -14rpx; }

.hero-title {
  position: relative;
  z-index: 2;
  font-size: 42rpx;
  font-weight: 700;
  color: #ffffff;
  line-height: 1.35;
  text-shadow: 0 4rpx 10rpx rgba(31, 109, 165, 0.25);
}

.hero-subtitle {
  position: relative;
  z-index: 2;
  margin-top: 10rpx;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.96);
}

.title {
  font-size: 34rpx;
  font-weight: 700;
  margin-bottom: 20rpx;
  color: #ffffff;
  text-shadow: 0 3rpx 8rpx rgba(24, 83, 46, 0.3);
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #e6fff0;
  margin-bottom: 14rpx;
  text-shadow: 0 3rpx 8rpx rgba(0, 0, 0, 0.18);
}

.meta {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
}

.btn-primary {
  background: rgba(255, 255, 255, 0.12);
  color: #ffffff;
  border: 1rpx solid rgba(255, 255, 255, 0.45);
  border-radius: 999rpx;
  font-weight: 700;
  box-shadow: 0 8rpx 20rpx rgba(13, 91, 47, 0.22);
}

.btn-soft {
  background: rgba(255, 255, 255, 0.08);
  color: #ffffff;
  border: 1rpx solid rgba(255, 255, 255, 0.36);
  border-radius: 999rpx;
}

.forest-btn {
  height: 88rpx;
  line-height: 88rpx;
  background:
    linear-gradient(180deg, rgba(129, 216, 144, 0.18), rgba(76, 175, 80, 0.14)),
    rgba(255, 255, 255, 0.08);
  color: #ffffff;
  border: 1rpx solid rgba(228, 255, 234, 0.58);
  border-radius: 999rpx;
  font-size: 34rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
  text-shadow: 0 4rpx 10rpx rgba(15, 68, 36, 0.45);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.35), 0 12rpx 24rpx rgba(22, 87, 47, 0.28);
}

.input {
  background: rgba(255, 255, 255, 0.26);
  border-radius: 14rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.5);
  padding: 16rpx;
  margin-bottom: 16rpx;
  color: #ffffff;
}

.input::placeholder { color: rgba(255, 255, 255, 0.78); }

.list-gap { margin-top: 8rpx; }

.mt-8 { margin-top: 8rpx; }
.mt-12 { margin-top: 12rpx; }
.mb-12 { margin-bottom: 12rpx; }
.mb-16 { margin-bottom: 16rpx; }
