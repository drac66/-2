page {
  background-color: #d9f4de;
  background-image: url('/assets/wallpaper.jpg');
  background-size: cover;
  background-position: center top;
  background-repeat: no-repeat;
  color: #153524;
  font-family: 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
}

.container {
  padding: 24rpx;
}

/* 通用内容卡片：降低透明度，保证可读性 */
.card {
  background: rgba(20, 78, 45, 0.55);
  border: 1rpx solid rgba(220, 255, 231, 0.55);
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 10rpx 24rpx rgba(10, 46, 26, 0.22);
}

/* 首页顶部天空区 */
.surface {
  position: relative;
  overflow: hidden;
  border-radius: 32rpx;
  padding: 28rpx 26rpx;
  margin-bottom: 22rpx;
  background: linear-gradient(180deg, rgba(55, 175, 255, 0.95), rgba(132, 224, 255, 0.9));
  border: 1rpx solid rgba(255, 255, 255, 0.55);
  box-shadow: 0 14rpx 30rpx rgba(37, 116, 180, 0.24);
}

.cloud {
  position: absolute;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 999rpx;
}

.cloud-a { width: 130rpx; height: 50rpx; top: 24rpx; right: 26rpx; }
.cloud-a-1 { width: 52rpx; height: 52rpx; top: 2rpx; right: 42rpx; }
.cloud-a-2 { width: 48rpx; height: 48rpx; top: 6rpx; right: 84rpx; }

.cloud-b { width: 108rpx; height: 40rpx; top: 86rpx; right: 136rpx; opacity: 0.88; }
.cloud-b-1 { width: 40rpx; height: 40rpx; top: 66rpx; right: 154rpx; opacity: 0.88; }
.cloud-b-2 { width: 36rpx; height: 36rpx; top: 70rpx; right: 188rpx; opacity: 0.88; }

.hero-title {
  position: relative;
  z-index: 2;
  font-size: 42rpx;
  font-weight: 700;
  color: #ffffff;
  line-height: 1.35;
  text-shadow: 0 4rpx 10rpx rgba(25, 98, 150, 0.28);
}

.hero-subtitle {
  position: relative;
  z-index: 2;
  margin-top: 10rpx;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.95);
}

.title {
  font-size: 34rpx;
  font-weight: 700;
  margin-bottom: 20rpx;
  color: #ffffff;
  text-shadow: 0 3rpx 8rpx rgba(0, 0, 0, 0.28);
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 12rpx;
}

.meta {
  font-size: 24rpx;
  color: rgba(241, 255, 245, 0.95);
}

/* 通用按钮 */
.btn-primary {
  background: rgba(37, 137, 80, 0.75);
  color: #ffffff;
  border: 1rpx solid rgba(225, 255, 231, 0.58);
  border-radius: 999rpx;
  font-weight: 700;
}

.btn-soft {
  background: rgba(23, 102, 58, 0.58);
  color: #ffffff;
  border: 1rpx solid rgba(225, 255, 231, 0.5);
  border-radius: 999rpx;
}

/* 首页四大入口：森林风 + 可读 */
.forest-btn {
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(180deg, rgba(95, 195, 118, 0.7), rgba(52, 150, 83, 0.68));
  color: #ffffff;
  border: 1rpx solid rgba(230, 255, 236, 0.65);
  border-radius: 999rpx;
  font-size: 34rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
  text-shadow: 0 3rpx 8rpx rgba(16, 70, 38, 0.45);
  box-shadow: 0 10rpx 22rpx rgba(15, 64, 35, 0.28);
}

.input {
  background: rgba(255, 255, 255, 0.85);
  border-radius: 14rpx;
  border: 1rpx solid rgba(226, 255, 235, 0.75);
  padding: 16rpx;
  margin-bottom: 16rpx;
  color: #133a25;
}

.input::placeholder {
  color: rgba(45, 95, 67, 0.6);
}

.list-gap { margin-top: 8rpx; }
.mt-8 { margin-top: 8rpx; }
.mt-12 { margin-top: 12rpx; }
.mb-12 { margin-bottom: 12rpx; }
.mb-16 { margin-bottom: 16rpx; }
