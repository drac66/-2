page {
  background-color: #f4fbff;
  background-image:
    linear-gradient(rgba(255, 255, 255, 0.72), rgba(255, 255, 255, 0.72)),
    url('/assets/wallpaper.jpg');
  background-size: cover;
  background-position: center;
  background-repeat: no-repeat;
  background-attachment: fixed;
  color: #1f2d3d;
  font-family: 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
}

.container { padding: 24rpx; }

.card {
  background: rgba(255, 255, 255, 0.9);
  border: 1rpx solid rgba(171, 220, 255, 0.58);
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 10rpx 28rpx rgba(74, 144, 226, 0.14);
  backdrop-filter: blur(8rpx);
}

.surface {
  background: rgba(255, 255, 255, 0.83);
  border: 1rpx solid rgba(162, 214, 255, 0.5);
  border-radius: 28rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 14rpx 32rpx rgba(63, 126, 214, 0.12);
}

.hero-title {
  font-size: 42rpx;
  font-weight: 700;
  color: #2f80ed;
  line-height: 1.35;
}

.hero-subtitle {
  margin-top: 10rpx;
  font-size: 26rpx;
  color: #4f6f8f;
}

.title {
  font-size: 34rpx;
  font-weight: 700;
  margin-bottom: 20rpx;
  color: #2f80ed;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #2d7fe8;
  margin-bottom: 14rpx;
}

.meta {
  font-size: 24rpx;
  color: #6283a6;
}

.btn-primary {
  background: linear-gradient(135deg, #63a4ff, #6fcf97 56%, #f9a8d4);
  color: #ffffff;
  border: none;
  border-radius: 999rpx;
  font-weight: 600;
}

.btn-soft {
  background: rgba(99, 164, 255, 0.12);
  color: #2f80ed;
  border: 1rpx solid rgba(111, 207, 151, 0.45);
  border-radius: 999rpx;
}

.input {
  background: rgba(255, 255, 255, 0.96);
  border-radius: 14rpx;
  border: 1rpx solid #cde7ff;
  padding: 16rpx;
  margin-bottom: 16rpx;
  color: #1f2d3d;
}

.list-gap { margin-top: 8rpx; }

.mt-8 { margin-top: 8rpx; }
.mt-12 { margin-top: 12rpx; }
.mb-12 { margin-bottom: 12rpx; }
.mb-16 { margin-bottom: 16rpx; }
