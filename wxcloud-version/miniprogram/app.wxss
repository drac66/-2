page {
  background-color: #eaf7ff;
  color: #1f2d3d;
  font-family: 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
}

.page-bg {
  position: fixed;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  z-index: 0;
  background-image: url('./assets/wallpaper.jpg');
  background-size: cover;
  background-position: center top;
  background-repeat: no-repeat;
}

.page-mask {
  position: fixed;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  z-index: 1;
  background: rgba(255, 255, 255, 0.08);
}

.page-shell {
  position: relative;
  z-index: 2;
  min-height: 100vh;
}

.container {
  padding: 24rpx;
}

/* 内容卡片：轻透，不要大绿块 */
.card {
  background: rgba(255, 255, 255, 0.38);
  border: 1rpx solid rgba(255, 255, 255, 0.66);
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 10rpx 24rpx rgba(31, 79, 122, 0.16);
}

/* 首页天空区 */
.surface {
  position: relative;
  overflow: hidden;
  border-radius: 32rpx;
  padding: 28rpx 26rpx;
  margin-bottom: 22rpx;
  background: linear-gradient(180deg, rgba(48, 182, 255, 0.9), rgba(130, 230, 255, 0.84));
  border: 1rpx solid rgba(255, 255, 255, 0.7);
  box-shadow: 0 14rpx 30rpx rgba(35, 114, 177, 0.2);
}

.cloud {
  position: absolute;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 999rpx;
}

.cloud-a { width: 126rpx; height: 48rpx; top: 24rpx; right: 24rpx; }
.cloud-a-1 { width: 52rpx; height: 52rpx; top: 0rpx; right: 44rpx; }
.cloud-a-2 { width: 46rpx; height: 46rpx; top: 4rpx; right: 82rpx; }
.cloud-b { width: 102rpx; height: 38rpx; top: 84rpx; right: 134rpx; opacity: 0.88; }
.cloud-b-1 { width: 40rpx; height: 40rpx; top: 64rpx; right: 152rpx; opacity: 0.88; }
.cloud-b-2 { width: 34rpx; height: 34rpx; top: 70rpx; right: 186rpx; opacity: 0.88; }

.hero-title {
  position: relative;
  z-index: 2;
  font-size: 42rpx;
  font-weight: 700;
  color: #ffffff;
  line-height: 1.35;
  text-shadow: 0 4rpx 10rpx rgba(27, 94, 153, 0.24);
}

.hero-subtitle {
  position: relative;
  z-index: 2;
  margin-top: 10rpx;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.96);
}

.title {
  font-size: 34rpx;
  font-weight: 700;
  margin-bottom: 20rpx;
  color: #ffffff;
  text-shadow: 0 3rpx 8rpx rgba(22, 64, 103, 0.28);
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 12rpx;
}

.meta {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.95);
}

/* 常规按钮：回到你更喜欢的渐变（非绿色块） */
.btn-primary {
  background: linear-gradient(135deg, rgba(96, 194, 255, 0.92), rgba(122, 233, 204, 0.9), rgba(255, 178, 223, 0.9));
  color: #ffffff;
  border: 1rpx solid rgba(255, 255, 255, 0.72);
  border-radius: 999rpx;
  font-weight: 700;
  box-shadow: 0 8rpx 20rpx rgba(62, 134, 184, 0.2);
}

.btn-soft {
  background: rgba(116, 199, 255, 0.45);
  color: #ffffff;
  border: 1rpx solid rgba(255, 255, 255, 0.68);
  border-radius: 999rpx;
}

/* 首页4个入口：森林感轮廓 + 渐变，不再是大绿块 */
.forest-btn {
  height: 88rpx;
  line-height: 88rpx;
  background:
    linear-gradient(135deg, rgba(123, 227, 168, 0.35), rgba(101, 195, 255, 0.36), rgba(255, 191, 227, 0.34)),
    rgba(255, 255, 255, 0.18);
  color: #ffffff;
  border: 1rpx solid rgba(235, 255, 241, 0.8);
  border-radius: 999rpx;
  font-size: 34rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
  text-shadow: 0 3rpx 8rpx rgba(20, 77, 52, 0.34);
  box-shadow: 0 10rpx 20rpx rgba(33, 94, 137, 0.18);
}

.input {
  background: rgba(255, 255, 255, 0.82);
  border-radius: 14rpx;
  border: 1rpx solid rgba(234, 246, 255, 0.95);
  padding: 16rpx;
  margin-bottom: 16rpx;
  color: #1f3750;
}

.input::placeholder {
  color: rgba(74, 106, 135, 0.6);
}

.list-gap { margin-top: 8rpx; }
.mt-8 { margin-top: 8rpx; }
.mt-12 { margin-top: 12rpx; }
.mb-12 { margin-bottom: 12rpx; }
.mb-16 { margin-bottom: 16rpx; }
