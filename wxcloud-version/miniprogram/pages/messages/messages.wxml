<view class="container">
  <view class="card">
    <view class="title">留言板</view>
    <input class="input" placeholder="写点想说的话..." bindinput="onInput" value="{{content}}" />
    <button class="btn-primary" bindtap="send">发送留言</button>
  </view>

  <block wx:for="{{list}}" wx:key="_id">
    <view class="card list-gap">
      <view class="section-title">{{item.sender_name}}</view>
      <view class="mt-8" style="white-space:pre-wrap">{{item.content}}</view>
      <view class="meta mt-8">{{item.show_time}}</view>
    </view>
  </block>
</view>
