<view class="container">
  <view class="card">
    <view class="title">{{ first ? '首次登录，先设置昵称' : '修改昵称' }}</view>
    <input class="input" maxlength="20" placeholder="请输入昵称（最多20字）" bindinput="onInput" value="{{nickname}}" />
    <button class="btn-primary" loading="{{saving}}" disabled="{{saving}}" bindtap="saveNickname">
      {{ saving ? '保存中...' : '保存昵称' }}
    </button>
  </view>
</view>
