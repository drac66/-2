<view class="page-bg"></view>
<view class="page-mask"></view>
<view class="container page-shell">
  <view class="surface">
    <view class="hero-title">欢迎回来</view>
    <view class="hero-subtitle">只给我们俩的小角落</view>
  </view>

  <view class="card">
    <view class="title">登录空间</view>
    <view class="meta mb-16">仅白名单用户可进入</view>
    <button class="btn-primary" loading="{{loggingIn}}" disabled="{{loggingIn}}" bindtap="wxLogin">
      {{ loggingIn ? '登录中...' : '微信一键登录' }}
    </button>
  </view>
</view>
