<image class="page-bg-image" src="/assets/wallpaper.jpg" mode="aspectFill"></image>
<view class="page-mask"></view>

<block wx:for="{{clickFx}}" wx:key="id">
  <view class="tap-ripple" style="left:{{item.x}}px;top:{{item.y}}px;"></view>
  <view class="tap-star star-a" style="left:{{item.x}}px;top:{{item.y}}px;">✦</view>
  <view class="tap-star star-b" style="left:{{item.x}}px;top:{{item.y}}px;">✦</view>
  <view class="tap-star star-c" style="left:{{item.x}}px;top:{{item.y}}px;">✦</view>
</block>

<view class="container page-shell" bindtap="onGlobalTap">
  <view class="surface">
    <view class="cloud cloud-a"></view>
    <view class="cloud cloud-a-1"></view>
    <view class="cloud cloud-a-2"></view>
    <view class="cloud cloud-b"></view>
    <view class="cloud cloud-b-1"></view>
    <view class="cloud cloud-b-2"></view>
    <view class="hero-title">🌿 我们的秘密空间</view>
    <view class="hero-subtitle">天空晴朗，慢慢逛我们的角落吧</view>
  </view>

  <view class="card">
    <button class="forest-btn mb-16" bindtap="toAlbum">相册</button>
    <button class="forest-btn mb-16" bindtap="toMessages">留言</button>
    <button class="forest-btn mb-16" bindtap="toDiary">日记</button>
    <button class="forest-btn mb-16" bindtap="toAI">GPT助手</button>
    <button class="forest-btn mb-16" bindtap="toSettings">设置</button>
    <button class="btn-soft" bindtap="logout">退出登录</button>
  </view>
</view>
