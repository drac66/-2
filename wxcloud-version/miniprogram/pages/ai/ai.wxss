.chat-wrap {
  height: 62vh;
  padding: 8rpx 4rpx;
  box-sizing: border-box;
}

.chat-scroll {
  height: calc(62vh - 56rpx);
}

.msg-row {
  display: flex;
  margin-top: 16rpx;
}

.msg-row.user {
  justify-content: flex-end;
}

.msg-row.assistant {
  justify-content: flex-start;
}

.msg-bubble {
  max-width: 76%;
  border-radius: 18rpx;
  padding: 14rpx 16rpx;
  box-sizing: border-box;
}

.msg-bubble.user {
  background: rgba(255, 90, 95, 0.88);
  color: #fff;
  border: 1rpx solid rgba(255, 60, 60, 0.45);
}

.msg-bubble.assistant {
  background: rgba(255, 255, 255, 0.92);
  color: #23313f;
  border: 1rpx solid rgba(255, 255, 255, 0.8);
}

.msg-meta {
  font-size: 20rpx;
  opacity: 0.75;
  margin-bottom: 6rpx;
}

.msg-content {
  white-space: pre-wrap;
  line-height: 1.6;
}

.file-link {
  margin-top: 8rpx;
  color: #2f80ed;
  font-size: 24rpx;
}

.pending-box {
  padding: 12rpx;
  border-radius: 14rpx;
  background: rgba(255,255,255,0.45);
  margin-bottom: 10rpx;
}

.pending-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 6rpx;
}

.pending-clear {
  color: #ff5a5f;
  font-size: 22rpx;
}

.pending-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 6rpx 0;
}

.pending-name {
  color: #1f2d3d;
  font-size: 24rpx;
  max-width: 520rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.pending-remove {
  color: #2f80ed;
  font-size: 22rpx;
}
