<image class="page-bg-image" src="/assets/wallpaper.jpg" mode="aspectFill"></image>
<view class="page-mask"></view>

<view class="container page-shell">
  <view class="card chat-wrap">
    <view class="title">GPT助手</view>
    <scroll-view class="chat-scroll" scroll-y="true" scroll-with-animation="true" scroll-into-view="{{scrollIntoView}}">
      <block wx:for="{{list}}" wx:key="_id">
        <view id="msg-{{item._id || index}}" class="msg-row {{item.role==='assistant' ? 'assistant' : 'user'}}">
          <view
            class="msg-bubble {{item.role==='assistant' ? 'assistant' : 'user'}}"
            data-text="{{item.content}}"
            data-role="{{item.role}}"
            bindlongpress="onMessageLongPress"
          >
            <view class="msg-meta">{{item.role === 'assistant' ? 'GPT' : '我'}} · {{item.show_time}}</view>
            <view class="msg-content">{{item.content}}</view>

            <block wx:if="{{item.files && item.files.length}}">
              <block wx:for="{{item.files}}" wx:key="fileID">
                <view class="file-link" data-url="{{item.tempFileURL}}" data-fileid="{{item.fileID}}" bindtap="openFile">
                  📎 {{item.name || '文件'}}（点我打开）
                </view>
              </block>
            </block>

            <view wx:if="{{(!item.files || !item.files.length) && item.fallbackUrl}}" class="file-link" data-url="{{item.fallbackUrl}}" bindtap="openFile">
              📎 打开文件（点我）
            </view>
          </view>
        </view>
      </block>
      <view id="chat-bottom-anchor" style="height: 2rpx;"></view>
    </scroll-view>
  </view>

  <view class="card">
    <view wx:if="{{pendingFiles.length}}" class="pending-box">
      <view class="pending-head">
        <text class="meta">待发送文件（{{pendingFiles.length}}）</text>
        <text class="pending-clear" bindtap="clearPendingFiles">清空</text>
      </view>
      <block wx:for="{{pendingFiles}}" wx:key="fileID">
        <view class="pending-item">
          <text class="pending-name">📄 {{item.name}}</text>
          <text class="pending-remove" data-index="{{index}}" bindtap="removePendingFile">移除</text>
        </view>
      </block>
    </view>

    <input
      class="input"
      placeholder="输入问题，或先上传PDF/Word..."
      value="{{input}}"
      bindinput="onInput"
      confirm-type="send"
      bindconfirm="onInputConfirm"
    />
    <button class="forest-btn mb-12" bindtap="chooseFile" loading="{{uploading}}">上传文件（支持多选）</button>
    <button class="forest-btn" bindtap="send" loading="{{sending}}">发送给GPT</button>
  </view>
</view>
