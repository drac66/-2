<image class="page-bg-image" src="/assets/wallpaper.jpg" mode="aspectFill"></image>
<view class="page-mask"></view>
<block wx:for="{{clickFx}}" wx:key="id">
  <view class="tap-ripple" style="left:{{item.x}}px;top:{{item.y}}px;"></view>
  <view class="tap-star star-a" style="left:{{item.x}}px;top:{{item.y}}px;">✦</view>
  <view class="tap-star star-b" style="left:{{item.x}}px;top:{{item.y}}px;">✦</view>
  <view class="tap-star star-c" style="left:{{item.x}}px;top:{{item.y}}px;">✦</view>
</block>

<view class="container page-shell" bindtap="onGlobalTap">
  <view class="card">
    <view class="title">相册</view>
    <input class="input" placeholder="写一句备注（可选）" bindinput="onNoteInput" value="{{note}}" />
    <button class="forest-btn mb-12" bindtap="chooseImage">上传图片</button>
    <button class="forest-btn" bindtap="chooseVideo">上传视频</button>
  </view>

  <block wx:for="{{list}}" wx:key="id">
    <view class="card list-gap">
      <view class="section-title">{{item.owner_name || item.owner}}</view>
      <view class="meta" style="white-space:pre-line">{{item.show_time}}</view>
      <view wx:if="{{item.note}}" class="mt-8">备注：{{item.note}}</view>
      <image
        wx:if="{{item.media_type==='image'}}"
        mode="widthFix"
        src="{{item.media_url}}"
        data-src="{{item.media_url}}"
        bindtap="previewImage"
        style="width:100%;margin-top:12rpx;border-radius:14rpx"
      />
      <video wx:if="{{item.media_type==='video'}}" src="{{item.media_url}}" controls style="width:100%;margin-top:12rpx;border-radius:14rpx" />
    </view>
  </block>
</view>
