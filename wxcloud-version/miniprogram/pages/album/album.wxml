<view class="container">
  <view class="card">
    <view class="title">相册</view>
    <input class="input" placeholder="写一句备注（可选）" bindinput="onNoteInput" value="{{note}}" />
    <button class="btn-primary mb-12" bindtap="chooseImage">上传图片</button>
    <button class="btn-soft" bindtap="chooseVideo">上传视频</button>
  </view>

  <block wx:for="{{list}}" wx:key="id">
    <view class="card list-gap">
      <view class="section-title">{{item.owner}}</view>
      <view class="meta">{{item.created_at}}</view>
      <view wx:if="{{item.note}}" class="mt-8">备注：{{item.note}}</view>
      <image wx:if="{{item.media_type==='image'}}" mode="widthFix" src="{{item.media_url}}" style="width:100%;margin-top:12rpx;border-radius:14rpx" />
      <video wx:if="{{item.media_type==='video'}}" src="{{item.media_url}}" controls style="width:100%;margin-top:12rpx;border-radius:14rpx" />
    </view>
  </block>
</view>
